*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{
font-family:Arial,sans-serif;
padding:20px;
background:#f5f5f5;
}

nav{
display:flex;
gap:20px;
background:#333;
padding:15px;
}

nav a{
color:white;
text-decoration:none;
}

section{
text-align:center;
padding:50px;
}

.project{
background:white;
padding:20px;
margin:15px 0;
border-radius:10px;
box-shadow:0 2px 5px rgba(0,0,0,0.2);
}

form{
background:white;
padding:20px;
border-radius:10px;
max-width:500px;
}

input,textarea{
width:100%;
padding:10px;
}

button{
padding:10px 20px;
background:blue;
color:white;
border:none;
cursor:pointer;
}

@media(max-width:768px){
nav{
flex-direction:column;
}
}
